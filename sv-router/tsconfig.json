{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023"],
		"module": "preserve",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.svelte"]
}
